# StructSim Frontend Environment Configuration
# Copy this file to .env.local and modify as needed

# Backend API URL
VITE_API_URL=http://localhost:5000/api/v1

# SSO Configuration
# Enable SSO mode (true for internal network, false for development)
VITE_SSO_ENABLED=false

# SSO Server URL (only needed when SSO is enabled)
VITE_SSO_SERVER_URL=http://sso.company.com

